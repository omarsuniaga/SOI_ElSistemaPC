{
  "version": "1.0.0",
  "canvas": {
    "backgroundColor": "#f1f5f9",
    "width": 1440,
    "height": 900
  },
  "nodes": [
    {
      "id": "frame-login-screen",
      "type": "frame",
      "name": "Portal de Maestros - Login Screen",
      "x": 0,
      "y": 0,
      "width": 1440,
      "height": 900,
      "backgroundColor": "#f1f5f9",
      "borderRadius": 0,
      "children": [
        {
          "id": "rect-login-container",
          "type": "rect",
          "name": "Main Container Card",
          "x": 120,
          "y": 50,
          "width": 1200,
          "height": 800,
          "fill": "#ffffff",
          "borderRadius": 32,
          "border": {
            "color": "rgba(0, 0, 0, 0.03)",
            "width": 1
          },
          "children": [
            {
              "id": "rect-form-side",
              "type": "rect",
              "name": "Left Form Side",
              "x": 120,
              "y": 50,
              "width": 600,
              "height": 800,
              "fill": "#ffffff",
              "borderRadius": 0,
              "children": [
                {
                  "id": "text-branding-logo",
                  "type": "text",
                  "name": "Branding Logo Icon",
                  "x": 380,
                  "y": 140,
                  "width": 80,
                  "height": 80,
                  "content": "🎵",
                  "fontSize": 48,
                  "fontWeight": 700,
                  "color": "#ffffff"
                },
                {
                  "id": "text-card-welcome",
                  "type": "text",
                  "name": "Card Title",
                  "x": 240,
                  "y": 240,
                  "width": 360,
                  "height": 36,
                  "content": "¡Te damos la bienvenida!",
                  "fontSize": 28,
                  "fontWeight": 800,
                  "color": "#0f172a"
                },
                {
                  "id": "text-card-subtitle",
                  "type": "text",
                  "name": "Card Subtitle",
                  "x": 240,
                  "y": 285,
                  "width": 360,
                  "height": 20,
                  "content": "Ingresa tus credenciales para continuar",
                  "fontSize": 13,
                  "fontWeight": 500,
                  "color": "#64748b"
                },
                {
                  "id": "group-input-email",
                  "type": "group",
                  "name": "Email Input Group",
                  "children": [
                    {
                      "id": "rect-input-email",
                      "type": "rect",
                      "name": "Email Input Bg [tag:input][id:pm-email][class:pm-input][type:email][placeholder:Correo electrónico]",
                      "x": 240,
                      "y": 330,
                      "width": 360,
                      "height": 48,
                      "fill": "#ffffff",
                      "borderRadius": 12,
                      "border": {
                        "color": "#cbd5e1",
                        "width": 1
                      }
                    },
                    {
                      "id": "text-placeholder-email",
                      "type": "text",
                      "name": "Email Placeholder Text",
                      "x": 256,
                      "y": 344,
                      "width": 300,
                      "height": 18,
                      "content": "Correo electrónico",
                      "fontSize": 14,
                      "fontWeight": 500,
                      "color": "#94a3b8"
                    }
                  ]
                },
                {
                  "id": "group-input-password",
                  "type": "group",
                  "name": "Password Input Group",
                  "children": [
                    {
                      "id": "rect-input-password",
                      "type": "rect",
                      "name": "Password Input Bg [tag:input][id:pm-password][class:pm-input][type:password][placeholder:Contraseña]",
                      "x": 240,
                      "y": 395,
                      "width": 360,
                      "height": 48,
                      "fill": "#ffffff",
                      "borderRadius": 12,
                      "border": {
                        "color": "#cbd5e1",
                        "width": 1
                      }
                    },
                    {
                      "id": "text-placeholder-password",
                      "type": "text",
                      "name": "Password Placeholder Text",
                      "x": 256,
                      "y": 409,
                      "width": 300,
                      "height": 18,
                      "content": "Contraseña",
                      "fontSize": 14,
                      "fontWeight": 500,
                      "color": "#94a3b8"
                    },
                    {
                      "id": "rect-btn-eye",
                      "type": "rect",
                      "name": "Btn Toggle Password [tag:button][id:pm-toggle-password][class:pm-password-toggle][type:button]",
                      "x": 560,
                      "y": 406,
                      "width": 26,
                      "height": 26,
                      "fill": "#f1f5f9",
                      "borderRadius": 6
                    }
                  ]
                },
                {
                  "id": "group-checkboxes",
                  "type": "group",
                  "name": "Preferences Group",
                  "children": [
                    {
                      "id": "rect-chk-remember",
                      "type": "rect",
                      "name": "Chk Remember [tag:input][id:pm-remember-email][type:checkbox]",
                      "x": 240,
                      "y": 465,
                      "width": 16,
                      "height": 16,
                      "fill": "#ffffff",
                      "borderRadius": 4,
                      "border": {
                        "color": "#cbd5e1",
                        "width": 1
                      }
                    },
                    {
                      "id": "text-lbl-remember",
                      "type": "text",
