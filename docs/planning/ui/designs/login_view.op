                      "x": 264,
                      "y": 466,
                      "width": 180,
                      "height": 14,
                      "content": "Recordarme por 30 días",
                      "fontSize": 12,
                      "fontWeight": 600,
                      "color": "#475569"
                    },
                    {
                      "id": "text-forgot-link",
                      "type": "text",
                      "name": "Forgot Password Link [tag:a][id:pm-forgot-link][class:pm-link-purple][href:#]",
                      "x": 460,
                      "y": 466,
                      "width": 140,
                      "height": 14,
                      "content": "¿Olvidaste tu contraseña?",
                      "fontSize": 12,
                      "fontWeight": 600,
                      "color": "#7c3aed"
                    }
                  ]
                },
                {
                  "id": "rect-btn-login",
                  "type": "rect",
                  "name": "Button Login [tag:button][id:pm-login-btn][class:pm-btn-lime][type:button]",
                  "x": 240,
                  "y": 510,
                  "width": 360,
                  "height": 48,
                  "fill": "#bef264",
                  "borderRadius": 12
                },
                {
                  "id": "text-btn-login-label",
