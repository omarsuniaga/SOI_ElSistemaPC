                  "x": 240,
                  "y": 640,
                  "width": 360,
                  "height": 16,
                  "content": "¿No tienes cuenta? Regístrate como maestro",
                  "fontSize": 12,
                  "fontWeight": 600,
                  "color": "#7c3aed"
                }
              ]
            },
            {
              "id": "rect-branding-side",
              "type": "rect",
              "name": "Right Branding Side",
              "x": 720,
              "y": 50,
              "width": 600,
              "height": 800,
              "fill": "#faf5ff",
              "borderRadius": 32,
              "children": [
                {
                  "id": "text-branding-title",
