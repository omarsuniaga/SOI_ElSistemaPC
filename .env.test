# Dummy Supabase env for the test suite.
# Vitest runs in `test` mode and Vite loads this file, so supabaseClient.js
# gets non-empty values and does not throw at import time. Tests mock all
# actual network/db calls — these values are never used to reach a real backend.
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=test-anon-key
