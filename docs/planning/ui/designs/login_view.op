                  "x": 340,
                  "y": 583,
                  "width": 200,
                  "height": 16,
                  "content": "🧬 Usar huella o Face ID",
                  "fontSize": 13,
                  "fontWeight": 600,
                  "color": "#0f172a"
                },
                {
                  "id": "text-register-link",
                  "type": "text",
