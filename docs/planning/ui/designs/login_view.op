                  "name": "Button Login Label",
                  "x": 380,
                  "y": 525,
                  "width": 100,
                  "height": 18,
                  "content": "Iniciar sesión",
                  "fontSize": 14,
                  "fontWeight": 700,
                  "color": "#0f172a"
                },
                {
                  "id": "rect-btn-biometric",
                  "type": "rect",
                  "name": "Button Biometric [tag:button][id:pm-biometric-btn][class:pm-btn-flat][type:button]",
