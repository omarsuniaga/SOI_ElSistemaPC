                  "name": "Branding Hero Subtitle",
                  "x": 780,
                  "y": 235,
                  "width": 480,
                  "height": 20,
                  "content": "by SOI - El Sistema Punta Cana",
                  "fontSize": 13,
                  "fontWeight": 600,
                  "color": "#64748b"
