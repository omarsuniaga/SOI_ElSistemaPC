                  "y": 570,
                  "width": 360,
                  "height": 45,
                  "fill": "#ffffff",
                  "borderRadius": 12,
                  "border": {
                    "color": "#cbd5e1",
                    "width": 1
                  }
                },
                {
                  "id": "text-btn-biometric-label",
